# UzMRC frontend-next environment

# Origin of the FastAPI backend the Next.js rewrite proxies /api/* to.
# Used at build/runtime by next.config.ts. Must NOT include a trailing slash.
# The backend serves under the /api prefix; the rewrite preserves it.
BACKEND_URL=http://localhost:8088

# Optional: hit the backend directly from the browser instead of via the
# same-origin /api proxy. Leave empty in normal (proxied) deployments.
# When set, axios baseURL becomes `${NEXT_PUBLIC_API_BASE}/api` and SSE URLs are
# built against it too. Must NOT include a trailing slash.
# NEXT_PUBLIC_API_BASE=http://localhost:8088
