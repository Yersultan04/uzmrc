# ─────────────────────────────────────────────────────────────────────────────
# rag-cms / UzMRC — пример конфигурации. Скопируй в .env и заполни секреты.
#   cp .env.example .env
# .env в .gitignore — секреты НИКОГДА не коммитятся.
# ─────────────────────────────────────────────────────────────────────────────

# ── Порты / биндинг (prod compose) ───────────────────────────────────────────
# По умолчанию всё слушает 127.0.0.1 (доступ только с самого хоста; наружу — через
# host-nginx с TLS). Для прямого доступа переопредели BIND=0.0.0.0 + нужный порт.
POSTGRES_BIND=127.0.0.1
POSTGRES_PORT=5435
QDRANT_BIND=127.0.0.1
QDRANT_HTTP_PORT=6335
QDRANT_GRPC_PORT=6336
BACKEND_BIND=127.0.0.1
BACKEND_PORT=8088
FRONTEND_BIND=127.0.0.1
FRONTEND_PORT=8090

# ── Postgres ─────────────────────────────────────────────────────────────────
POSTGRES_USER=ragcms
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=ragcms

# ── Auth / JWT ───────────────────────────────────────────────────────────────
# Сгенерировать: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=CHANGE_ME_run_token_urlsafe_48
JWT_TTL_HOURS=24
# Bootstrap первого админа: при пустой таблице users аккаунт создаётся на старте.
BOOTSTRAP_ADMIN_EMAIL=admin@uzmrc.io
BOOTSTRAP_ADMIN_PASSWORD=CHANGE_ME_strong_admin_password

# ── CORS / язык ──────────────────────────────────────────────────────────────
CORS_ORIGINS=https://rag-cms.eskender.tech
DEFAULT_FTS_LANGUAGE=russian

# ── Эмбеддинги ───────────────────────────────────────────────────────────────
# Рекомендация MVP: Voyage (мультиязычный ru+uz, проверен на корпусе).
# Привяжи карту в Voyage billing, чтобы снять free-лимит 3 RPM.
EMBED_PROVIDER=voyage
VOYAGE_API_KEY=CHANGE_ME_voyage_key
VOYAGE_EMBED_MODEL=voyage-3.5
VOYAGE_EMBED_DIM=1024
# Voyage dedicated reranker для Модуля 2 (per-clause точность). Пусто → фолбэк на LLM-rerank.
VOYAGE_RERANK_MODEL=rerank-2.5
# Клиентский rate-pacing для Voyage (free tier 3 RPM/10K TPM). На платном — подними/обнули.
# (см. config: voyage_rpm / voyage_tpm)

# ── OpenAI-совместимый эмбеддер (альтернатива Voyage: Gemini / Jina / TEI / bge-m3) ──
# Активен при EMBED_PROVIDER=openai. Оставь пустым при Voyage.
EMBED_API_BASE_URL=
EMBED_API_KEY=
EMBED_MODEL_NAME=
EMBED_DIM=1024
EMBED_RPM=0
EMBED_TPM=0

# ── LLM (судья Модуля 2 + ReAct-агент Модуля 1) ──────────────────────────────
# OpenRouter — общий ключ-фолбэк для всех LLM-ролей, если роль не переопределена.
OPENROUTER_API_KEY=CHANGE_ME_openrouter_key
# Роль chat/судья. Пусто base_url → используется OpenRouter (OPENROUTER_API_KEY).
# Рекомендация MVP: Cerebras gpt-oss-120b (быстрый инференс). Для этого задай base+key:
LLM_API_BASE_URL=https://api.cerebras.ai/v1
LLM_API_KEY=CHANGE_ME_cerebras_key
LLM_MODEL=gpt-oss-120b
# Reranker (если не используется Voyage rerank выше).
RERANK_API_BASE_URL=https://api.cerebras.ai/v1
RERANK_API_KEY=CHANGE_ME_cerebras_key
LLM_RERANK_MODEL=gpt-oss-120b
# Vision/OCR fallback для PDF-страниц с малым текстом.
LLM_VISION_MODEL=qwen/qwen3-vl-30b-a3b-instruct
# Кросс-провайдер фолбэк судьи (надёжность). Рекомендация: OpenRouter (платный).
LLM_FALLBACK_API_BASE_URL=https://openrouter.ai/api/v1
LLM_FALLBACK_API_KEY=CHANGE_ME_openrouter_key
LLM_FALLBACK_MODEL=openai/gpt-oss-120b

# ── Логирование ──────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
